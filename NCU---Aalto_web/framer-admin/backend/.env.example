# ─────────────────────────────────────────
# .env.example — 環境變數範本
# ─────────────────────────────────────────
# 使用方法：複製這個檔案並重新命名為 .env，再填入實際的值
# cp .env.example .env

# JWT 簽名密鑰（必填，請改成隨機字串）
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Token 有效時間（小時），預設 24 小時
TOKEN_EXPIRE_HOURS=24

# ── 資料庫設定（二選一）──

# 選項 A：本機開發用 SQLite（預設，不需安裝任何東西）
DATABASE_URL=sqlite:///./admin.db

# 選項 B：VPS 正式環境用 PostgreSQL（上線時改這行）
# DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST_IP:5432/DATABASE_NAME

# 管理員帳號設定（執行 seed.py 時使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-here
