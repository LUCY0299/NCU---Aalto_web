# ─────────────────────────────────────────
# .gitignore — Git 忽略檔案清單
# ─────────────────────────────────────────

# 環境變數（含密鑰，絕對不能上傳！）
.env
*.env

# Python 暫存檔
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 虛擬環境
venv/
env/
.venv/

# SQLite 資料庫（本機資料，不需同步）
*.db
*.sqlite
*.sqlite3

# IDE 設定
.vscode/settings.json
.idea/
*.swp

# macOS
.DS_Store

# Windows
Thumbs.db

# 日誌
*.log
logs/

# 測試覆蓋率
.coverage
htmlcov/
